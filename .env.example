# Copy to `.env` and tweak.
#
# This file has three sections:
#
#   (1) Production management-plane stack (docker-compose.yml on the
#       admin VPS) — variables interpolated into the six management
#       services. Values without a sensible default MUST be set before
#       `docker compose up`.
#
#   (2) Worker stack (docker-compose.worker.yml on each worker VPS) —
#       variables interpolated into the axis-agent sidecar that sits
#       next to the project's own compose file. Values without a
#       sensible default MUST be set before `docker compose up`.
#
#   (3) Local dev (host-run processes) — AXIS_CONTROL_* / AXIS_AGENT_*
#       prefixes consumed by Pydantic settings when you run the Python
#       processes directly with `uv run` against docker-compose.dev.yml.
#
# In production, axis-control runs INSIDE its container and receives
# env from the `environment:` block of docker-compose.yml; section (3)
# below is not consulted then. Same goes for axis-agent on workers and
# section (2).

# ========================================================================
# (1) Production stack — referenced by docker-compose.yml
# ========================================================================

# Postgres credentials. POSTGRES_PASSWORD has no default and MUST be set.
POSTGRES_USER=axis
POSTGRES_PASSWORD=change-me
POSTGRES_DB=axis

# Grafana initial admin password. MUST be set; Grafana refuses to start
# with the default `admin` password in recent versions.
GRAFANA_ADMIN_PASSWORD=change-me

# Image tag pulled from GHCR for the axis-control service. Pin to a
# specific MAJOR.MINOR.PATCH on the VPS; the default tracks `:latest`
# which is convenient for staging but unsafe for production.
AXIS_CONTROL_IMAGE_TAG=latest

# Hostname the operator uses to reach the admin API. Caddy reverse-
# proxies axis-control on this domain and obtains a Let's Encrypt cert
# for it automatically.
#
# Production: bare hostname (e.g. `admin.axis.example`) — Caddy auto-
#   issues a TLS cert and redirects HTTP → HTTPS.
# Local sanity check: prefix with `http://` (e.g. `http://localhost`)
#   to opt out of auto-HTTPS, since ACME cannot issue for `localhost`.
ADMIN_DOMAIN=admin.example.com

# Shared bootstrap secret an agent must present (as
# `Authorization: Bearer <token>`) when calling POST /api/instances.
# Without this set the registration endpoint refuses every request, so
# production MUST set it before bringing the stack up. The same value
# goes to each worker as AXIS_AGENT_REGISTRATION_TOKEN.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AXIS_CONTROL_REGISTRATION_TOKEN=change-me

# --- Backup sidecar (#18) -----------------------------------------------
# The `backup` service in docker-compose.yml runs pg_dump + a vmsingle
# snapshot on a cron schedule and uploads each artifact to an
# S3-compatible bucket. The named volumes are otherwise vulnerable to a
# VPS disk failure or a fat-fingered `docker compose down -v`.
#
# Endpoint hint for Timeweb Cloud S3: `https://s3.timeweb.cloud`. Any
# S3-compatible bucket works (Wasabi, Backblaze B2, MinIO, AWS S3 …) —
# only the endpoint + region change.
#
# Encryption-at-rest is trusted to the bucket (Timeweb and every major
# S3 provider encrypt by default). The application does NOT encrypt
# uploads — if your threat model includes a provider compromise, layer
# `age`/`sops` over the artifacts before upload as a follow-up.
AXIS_BACKUP_S3_ENDPOINT=https://s3.timeweb.cloud
AXIS_BACKUP_S3_BUCKET=change-me
AXIS_BACKUP_S3_PREFIX=axis-control
AXIS_BACKUP_S3_ACCESS_KEY_ID=change-me
AXIS_BACKUP_S3_SECRET_ACCESS_KEY=change-me
AXIS_BACKUP_S3_REGION=ru-1

# Optional. Defaults baked into both compose and the image entrypoint:
#   AXIS_BACKUP_CRON                 0 2 * * *   (daily, 02:00 UTC)
#   AXIS_BACKUP_LOCAL_RETENTION_DAYS 7
#   AXIS_BACKUP_IMAGE_TAG            latest
# Override on the VPS if the defaults do not fit. Remote retention is
# NOT managed from the container — set a bucket lifecycle rule on the
# Timeweb side (e.g. "expire objects under axis-control/ after 90
# days") rather than giving the backup image delete permissions.
# AXIS_BACKUP_CRON=0 2 * * *
# AXIS_BACKUP_LOCAL_RETENTION_DAYS=7
# AXIS_BACKUP_IMAGE_TAG=latest
#
# Restore (manual, on the management VPS):
#   1. Download the artifact:
#        aws --endpoint-url $AXIS_BACKUP_S3_ENDPOINT s3 cp \
#          s3://$AXIS_BACKUP_S3_BUCKET/$AXIS_BACKUP_S3_PREFIX/postgres/postgres-<ts>.sql.gz .
#   2. With the stack DOWN except for postgres:
#        gunzip -c postgres-<ts>.sql.gz | \
#          docker compose exec -T postgres psql -U $POSTGRES_USER $POSTGRES_DB
#   3. vmsingle restore: extract the tarball into the vmsingle data
#      volume while the service is stopped, then bring vmsingle back
#      with `-storageDataPath` pointing at the restored dir. See the
#      VictoriaMetrics docs for `vmrestore` if you need point-in-time
#      precision rather than a full snapshot swap.
# A restore drill belongs on the operator's calendar — without one,
# the bucket might as well be /dev/null.

# ========================================================================
# (2) Worker stack — referenced by docker-compose.worker.yml on workers
# ========================================================================

# Logical project this worker runs. Used at first-time self-registration
# to create / look up the `projects` row. Stick to a stable slug —
# changing it later creates a new project row and orphans the old one.
# AXIS_AGENT_PROJECT_NAME=text-assistant

# Base URL of the management-plane admin API. The agent calls
# `POST /api/instances` here at first start and caches the assigned UUID.
# Must be reachable from the worker (typically the same HTTPS URL the
# operator uses; caddy fronts it).
# AXIS_AGENT_CONTROL_PLANE_URL=https://admin.example.com

# NATS broker URL on the management VPS. The agent subscribes to
# `commands.<instance_id>` and publishes heartbeats + status reports.
# Messages carry the per-instance agent token (#8) so a third party
# reachable to the broker can publish to the subjects but cannot move
# any control-plane state. Connection-level NATS auth is a separate
# follow-up; until then the broker should stay on a private network.
# AXIS_AGENT_NATS_URL=nats://admin.example.com:4222

# Shared bootstrap secret presented to the control plane at first
# start (must match AXIS_CONTROL_REGISTRATION_TOKEN on the management
# VPS). Required unless AXIS_AGENT_INSTANCE_ID overrides registration.
# AXIS_AGENT_REGISTRATION_TOKEN=change-me

# Absolute path on the worker host to the project's docker-compose.yml.
# Bind-mounted into the agent container at the SAME path, so
# `docker compose -f $AXIS_AGENT_COMPOSE_FILE stop/start` works
# identically inside and outside the container.
# AXIS_AGENT_COMPOSE_FILE=/srv/text-assistant/docker-compose.yml

# GHCR tag for the axis-agent image. Pin to a MAJOR.MINOR.PATCH on each
# worker; `latest` is convenient for staging.
# AXIS_AGENT_IMAGE_TAG=latest

# Optional — defaults to the OS hostname of the worker VPS.
# AXIS_AGENT_HOSTNAME=worker-acme-01

# ========================================================================
# (3) Local dev — host-run `uv run axis-control` / `uv run axis-agent`
# ========================================================================

# --- axis-control --------------------------------------------------------
AXIS_CONTROL_DATABASE_URL=postgresql://axis:axis@127.0.0.1:5432/axis
AXIS_CONTROL_NATS_URL=nats://127.0.0.1:4222
AXIS_CONTROL_HTTP_HOST=0.0.0.0
AXIS_CONTROL_HTTP_PORT=8000
AXIS_CONTROL_LOG_LEVEL=INFO

# Shared bootstrap secret required on POST /api/instances. Without
# this the endpoint rejects every request. Mirror it into
# AXIS_AGENT_REGISTRATION_TOKEN below.
AXIS_CONTROL_REGISTRATION_TOKEN=dev-bootstrap-token

# Pending commands are moved to `failed` after this many seconds without
# an agent acknowledgement. Instance status is NOT inferred from a
# timeout — only the command is finalised.
AXIS_CONTROL_COMMAND_TIMEOUT_SECONDS=60
AXIS_CONTROL_COMMAND_SWEEP_INTERVAL_SECONDS=5
# Per-publish probe to detect a missing agent at dispatch time, surfaced
# as `delivery: no_listeners` in the API response. Sets a lower bound on
# publish latency on the happy path.
AXIS_CONTROL_NATS_PUBLISH_PROBE_TIMEOUT=0.1

# Heartbeat freshness window. An instance whose last_heartbeat_at is older
# than this many seconds is reported as `reachability: offline`. Should be
# a multiple of AXIS_AGENT_HEARTBEAT_INTERVAL_SECONDS so a single missed
# publish does not flip the instance offline.
AXIS_CONTROL_HEARTBEAT_STALE_SECONDS=30

# --- axis-agent ----------------------------------------------------------
# Self-registration: set the project this worker runs and where to find
# the control plane. The agent registers itself on first start, persists
# the assigned instance_id (plus the minted agent_token), and reuses
# them on every restart afterwards.
AXIS_AGENT_PROJECT_NAME=text-assistant
AXIS_AGENT_CONTROL_PLANE_URL=http://127.0.0.1:8000
# Must match AXIS_CONTROL_REGISTRATION_TOKEN on the control plane.
AXIS_AGENT_REGISTRATION_TOKEN=dev-bootstrap-token
# Optional: defaults to OS hostname.
# AXIS_AGENT_HOSTNAME=worker-acme-01

AXIS_AGENT_NATS_URL=nats://127.0.0.1:4222

# How often the agent publishes a heartbeat on heartbeat.<instance_id>.
# Should be a small fraction of AXIS_CONTROL_HEARTBEAT_STALE_SECONDS.
AXIS_AGENT_HEARTBEAT_INTERVAL_SECONDS=10

# Optional override — when set, bypasses both the persisted state and the
# self-registration step. Useful for pinning an agent to a specific row.
# AXIS_AGENT_INSTANCE_ID=00000000-0000-0000-0000-000000000000

# Optional: where the assigned instance_id is cached on disk. Defaults to
# %LOCALAPPDATA%\axis-agent on Windows, $XDG_STATE_HOME/axis-agent
# (typically ~/.local/state/axis-agent) on Linux/Mac. Delete this
# directory — or run `axis-agent --reset-identity` — to force re-registration.
# AXIS_AGENT_STATE_DIR=/var/lib/axis-agent

# `logging` = dry-run (default, safe). `docker` = actually run docker compose.
AXIS_AGENT_COMPOSE_MODE=logging
# Required only when COMPOSE_MODE=docker:
# AXIS_AGENT_COMPOSE_FILE=/abs/path/to/worker/docker-compose.yml
# AXIS_AGENT_COMPOSE_PROJECT=text-assistant

AXIS_AGENT_LOG_LEVEL=INFO
