# Copy to `.env` and tweak. Both `axis-control` and `axis-agent` read this
# (each only consumes its own prefix, so they happily share one file).

# --- axis-control --------------------------------------------------------
AXIS_CONTROL_DATABASE_URL=postgresql://axis:axis@127.0.0.1:5432/axis
AXIS_CONTROL_NATS_URL=nats://127.0.0.1:4222
AXIS_CONTROL_HTTP_HOST=0.0.0.0
AXIS_CONTROL_HTTP_PORT=8000
AXIS_CONTROL_LOG_LEVEL=INFO

# --- axis-agent ----------------------------------------------------------
# Get this UUID by POSTing to /api/instances on a running axis-control.
# AXIS_AGENT_INSTANCE_ID=00000000-0000-0000-0000-000000000000
AXIS_AGENT_NATS_URL=nats://127.0.0.1:4222

# `logging` = dry-run (default, safe). `docker` = actually run docker compose.
AXIS_AGENT_COMPOSE_MODE=logging
# Required only when COMPOSE_MODE=docker:
# AXIS_AGENT_COMPOSE_FILE=/abs/path/to/worker/docker-compose.yml
# AXIS_AGENT_COMPOSE_PROJECT=text-assistant

AXIS_AGENT_LOG_LEVEL=INFO
